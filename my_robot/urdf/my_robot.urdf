<?xml version="1.0" encoding="utf-8"?>
<robot name="my_robot">

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://my_robot/meshes/base_link.STL"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://my_robot/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <link name="link_wheel_1">
    <inertial>
      <origin xyz="0 0 0.012" rpy="0 0 0"/>
      <mass value="0.35"/>
      <inertia ixx="1.3e-5" ixy="0" ixz="0" iyy="1.3e-5" iyz="0" izz="2.3e-5"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://my_robot/meshes/link_wheel_1.STL"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://my_robot/meshes/link_wheel_1.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_wheel_1" type="continuous">
    <origin xyz="0 0.1315 -0.02" rpy="1.5708 0 3.1416"/>
    <parent link="base_link"/>
    <child link="link_wheel_1"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <link name="link_wheel_2">
    <inertial>
      <origin xyz="0 0 0.006" rpy="0 0 0"/>
      <mass value="0.06"/>
      <inertia ixx="1.3e-5" ixy="0" ixz="0" iyy="1.3e-5" iyz="0" izz="2.3e-5"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://my_robot/meshes/link_wheel_2.STL"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://my_robot/meshes/link_wheel_2.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_wheel_2" type="continuous">
    <origin xyz="-0.11908 -0.06875 -0.02" rpy="1.5708 0 -1.0472"/>
    <parent link="base_link"/>
    <child link="link_wheel_2"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <link name="link_wheel_3">
    <inertial>
      <origin xyz="0 0 0.047" rpy="0 0 0"/>
      <mass value="0.06"/>
      <inertia ixx="1.3e-5" ixy="0" ixz="0" iyy="1.3e-5" iyz="0" izz="2.3e-5"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://my_robot/meshes/link_wheel_3.STL"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://my_robot/meshes/link_wheel_3.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_wheel_3" type="continuous">
    <origin xyz="0.082948 -0.04789 -0.02" rpy="1.5708 0 1.0472"/>
    <parent link="base_link"/>
    <child link="link_wheel_3"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="joint_arm_dung" type="prismatic">
    <origin xyz="0 0 0.21658" rpy="1.5708 0 0"/>
    <parent link="base_link"/>
    <child link="link_arm_dung"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.125" upper="0.02" effort="5" velocity="0.25"/>
    <dynamics damping="0.2" friction="0.02"/>
  </joint>

  <link name="link_arm_dung">
    <inertial>
      <origin xyz="0.02 0.01 0.0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://my_robot/meshes/link_arm_dung.STL"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="joint_arm_ngang" type="prismatic">
    <origin xyz="0.045 0.045 -0.056" rpy="0 0 0"/>
    <parent link="link_arm_dung"/>
    <child link="link_arm_ngang"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.035" upper="0.045" effort="5" velocity="0.1"/>
    <dynamics damping="0.2" friction="0.02"/>
  </joint>

  <link name="link_arm_ngang">
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://my_robot/meshes/link_arm_ngang.STL"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <link name="link_lidar">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.005"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://my_robot/meshes/link_lidar.STL"/>
      </geometry>
    </visual>
  </link>

  <joint name="joint_lidar" type="fixed">
    <origin xyz="0 0.11 0.08" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link_lidar"/>
  </joint>

  <gazebo>
    <plugin filename="libignition-gazebo-sensors-system.so" name="ignition::gazebo::systems::Sensors"/>
    <plugin filename="libignition-gazebo-scene-broadcaster-system.so" name="ignition::gazebo::systems::SceneBroadcaster"/>
    <plugin filename="libignition-gazebo-joint-state-publisher-system.so" name="ignition::gazebo::systems::JointStatePublisher">
      <topic>/joint_states</topic>
      <joint_name>joint_wheel_1</joint_name>
      <joint_name>joint_wheel_2</joint_name>
      <joint_name>joint_wheel_3</joint_name>
      <joint_name>joint_arm_dung</joint_name>
      <joint_name>joint_arm_ngang</joint_name>
    </plugin>
    <plugin filename="libignition-gazebo-odometry-publisher-system.so" name="ignition::gazebo::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <dimensions>2</dimensions>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>
    <plugin filename="libignition-gazebo-joint-controller-system.so" name="ignition::gazebo::systems::JointController">
      <joint_name>joint_wheel_1</joint_name>
      <topic>/wheel_1_cmd</topic>
      <use_force_commands>false</use_force_commands>
    </plugin>
    <plugin filename="libignition-gazebo-joint-controller-system.so" name="ignition::gazebo::systems::JointController">
      <joint_name>joint_wheel_2</joint_name>
      <topic>/wheel_2_cmd</topic>
      <use_force_commands>false</use_force_commands>
    </plugin>
    <plugin filename="libignition-gazebo-joint-controller-system.so" name="ignition::gazebo::systems::JointController">
      <joint_name>joint_wheel_3</joint_name>
      <topic>/wheel_3_cmd</topic>
      <use_force_commands>false</use_force_commands>
    </plugin>
    <plugin filename="libignition-gazebo-joint-position-controller-system.so" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>joint_arm_dung</joint_name>
      <topic>/arm_dung_cmd</topic>
      <p_gain>220.0</p_gain>
      <i_gain>8.0</i_gain>
      <d_gain>12.0</d_gain>
      <i_max>60.0</i_max>
      <i_min>-60.0</i_min>
      <cmd_max>1500</cmd_max>
      <cmd_min>-800</cmd_min>
    </plugin>
    <plugin filename="libignition-gazebo-joint-position-controller-system.so" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>joint_arm_ngang</joint_name>
      <topic>/arm_ngang_cmd</topic>
      <p_gain>220.0</p_gain>
      <i_gain>8.0</i_gain>
      <d_gain>12.0</d_gain>
      <i_max>60.0</i_max>
      <i_min>-60.0</i_min>
      <cmd_max>1200</cmd_max>
      <cmd_min>-1200</cmd_min>
    </plugin>
  </gazebo>

  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <topic>/imu</topic>
    </sensor>
  </gazebo>

  <gazebo reference="link_lidar">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>/scan</topic>
      <lidar>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <gazebo reference="link_wheel_1">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <gazebo reference="link_wheel_2">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <gazebo reference="link_wheel_3">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
  </gazebo>

</robot>
